#!/bin/sh
set -e

mount -t proc none /proc
mount -t sysfs none /sys
mount -t devtmpfs none /dev

echo "Kernel commandline: $(cat /proc/cmdline)"

# Defaults
#root=/dev/dm-0
root=/dev/mapper/rootfs
init=/sbin/init

# --- Parse verity parameters from /proc/cmdline ---
for param in $(cat /proc/cmdline); do
    case $param in
        verity.sectors=*)   SECTORS="${param#verity.sectors=}" ;;
        verity.blksize=*)   BLOCK_SIZE="${param#verity.blksize=}" ;;
        verity.datablocks=*) DATA_BLOCKS="${param#verity.datablocks=}" ;;
        verity.hashstart=*) HASH_START="${param#verity.hashstart=}" ;;
        verity.roothash=*)  ROOT_HASH="${param#verity.roothash=}" ;;
        verity.salt=*)      SALT="${param#verity.salt=}" ;;
    esac
done

echo "dm-verity params:"
echo "  SECTORS=${SECTORS}"
echo "  BLOCK_SIZE=${BLOCK_SIZE}"
echo "  DATA_BLOCKS=${DATA_BLOCKS}"
echo "  HASH_START=${HASH_START}"
echo "  ROOT_HASH=${ROOT_HASH}"
echo "  SALT=${SALT}"

# Wait for the data device (rootfs partition)
DATA_DEV=/dev/mmcblk1p2
HASH_DEV=/dev/mmcblk1p3
echo "Waiting for ${DATA_DEV}..."
for i in $(seq 1 20); do
    if [ -b "${DATA_DEV}" ]; then
        echo "${DATA_DEV} found."
        break
    fi
    echo "  Attempt $i: ${DATA_DEV} not ready, retrying..."
    sleep 1
done

if [ ! -b "${DATA_DEV}" ]; then
    echo "ERROR: ${DATA_DEV} not found! Dropping to shell."
    exec /bin/sh
fi

echo "Waiting for ${HASH_DEV}..."
for i in $(seq 1 20); do
    if [ -b "${HASH_DEV}" ]; then
        echo "${HASH_DEV} found."
        break
    fi
    echo "  Attempt $i: ${HASH_DEV} not ready, retrying..."
    sleep 1
done

if [ ! -b "${HASH_DEV}" ]; then
    echo "ERROR: ${HASH_DEV} not found! Dropping to shell."
    exec /bin/sh
fi

# Create dm-verity mapping
#TABLE="0 ${SECTORS} verity 1 ${DATA_DEV} ${HASH_DEV} ${BLOCK_SIZE} ${BLOCK_SIZE} ${DATA_BLOCKS} ${HASH_START} sha256 ${ROOT_HASH} ${SALT}"
#echo "Creating dm-verity mapping..."
#echo "dmsetup create --readonly rootfs --table $TABLE"
#dmsetup create --readonly rootfs --table "$TABLE"
echo "Creating dm-verity mapping with veritysetup..."
HASH_OFFSET=$((HASH_START * BLOCK_SIZE))
veritysetup create rootfs $DATA_DEV $HASH_DEV \
   --hash-offset=$HASH_OFFSET \
   --data-blocks=$DATA_BLOCKS \
   --data-block-size=$BLOCK_SIZE \
   --hash-block-size=$BLOCK_SIZE \
   --salt=$SALT \
   $ROOT_HASH

# Wait for /dev/dm-0
for i in $(seq 1 10); do
    if [ -b "$root" ]; then
        echo "dm-verity device $root created."
        break
    fi
    echo "  Attempt $i: $root not ready, retrying..."
    sleep 1
done

if [ ! -b "$root" ]; then
    echo "ERROR: $root not found. Dropping to shell."
    ls -lah /dev/mapper /dev/dm*
    exec /bin/sh
fi

echo "Mounting $root read-only as rootfs..."
mount -o ro "$root" /sysroot

# Switch to the real root
exec switch_root /sysroot "$init"
